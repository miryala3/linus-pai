#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  Linus PAI — self-contained launcher                                        ║
# ║  https://github.com/miryala3/linus-pai                                      ║
# ║                                                                              ║
# ║  No Python installation required. Run this file directly:                   ║
# ║    chmod +x pai && ./pai                                                     ║
# ║    ./pai --chat                                                              ║
# ║    ./pai --doctor                                                            ║
# ║                                                                              ║
# ║  On first run: downloads a self-contained Python 3.12 runtime (~70 MB)      ║
# ║  and compiles the GPU backend. Takes 5–15 minutes once, then instant.       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
PAI_VERSION="1.0.0"
PAI_PYTHON_VERSION="3.12.8"
PAI_PYTHON_RELEASE="20250115"
PAI_HOME="${PAI_HOME:-${HOME}/.linus-pai}"
PAI_PYTHON_DIR="${PAI_HOME}/python"
PAI_VENV_DIR="${PAI_HOME}/venv"
PAI_LOCK="${PAI_HOME}/.bootstrap.lock"
PAI_LOG="${PAI_HOME}/bootstrap.log"
# Resolve symlinks so that pai.py is found next to the real script,
# not next to a symlink in ~/.local/bin/ that has no pai.py beside it.
# Works on macOS (BSD readlink) and Linux (GNU readlink).
_pai_resolve_self() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local link
    link="$(readlink "$src")"
    # Relative symlink — make it absolute relative to the symlink's dir
    [[ "$link" != /* ]] && link="$(dirname "$src")/$link"
    src="$link"
  done
  echo "$src"
}
PAI_REAL_SCRIPT="$(_pai_resolve_self)"
PAI_SCRIPT_DIR="$(cd "$(dirname "${PAI_REAL_SCRIPT}")" && pwd)"
PAI_SCRIPT="${PAI_SCRIPT_DIR}/pai.py"

# Allow overriding the Python binary (skip embedded download)
PAI_PYTHON_BIN="${PAI_PYTHON:-}"

mkdir -p "${PAI_HOME}"

# ── Colours ───────────────────────────────────────────────────────────────────
if [ -t 1 ]; then
  BOLD='\033[1m'; DIM='\033[2m'
  CYAN='\033[36m'; GREEN='\033[32m'; YELLOW='\033[33m'; RED='\033[31m'
  RESET='\033[0m'
else
  BOLD=''; DIM=''; CYAN=''; GREEN=''; YELLOW=''; RED=''; RESET=''
fi

_banner() {
  printf "${BOLD}${CYAN}"
  printf "  ██╗     ██╗███╗   ██╗██╗   ██╗███████╗    ██████╗  █████╗ ██╗\n"
  printf "  ██║     ██║████╗  ██║██║   ██║██╔════╝    ██╔══██╗██╔══██╗██║\n"
  printf "  ██║     ██║██╔██╗ ██║██║   ██║███████╗    ██████╔╝███████║██║\n"
  printf "  ██║     ██║██║╚██╗██║██║   ██║╚════██║    ██╔═══╝ ██╔══██║██║\n"
  printf "  ███████╗██║██║ ╚████║╚██████╔╝███████║    ██║     ██║  ██║██║\n"
  printf "  ╚══════╝╚═╝╚═╝  ╚═══╝ ╚═════╝ ╚══════╝    ╚═╝     ╚═╝  ╚═╝╚═╝\n"
  printf "${RESET}  Private AI Runtime v${PAI_VERSION}  ·  github.com/miryala3/linus-pai\n\n"
}

info()  { printf "${CYAN}[PAI]${RESET} %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${RESET}  %s\n" "$*"; }
warn()  { printf "${YELLOW}[!!]${RESET}  %s\n" "$*"; }
err()   { printf "${RED}[ERR]${RESET} %s\n" "$*" >&2; }
die()   { err "$*"; exit 1; }

# ── Quick exit for --version / --help before bootstrap ────────────────────────
for arg in "$@"; do
  if [[ "$arg" == "--version" || "$arg" == "-V" ]]; then
    echo "Linus PAI v${PAI_VERSION} (Python ${PAI_PYTHON_VERSION})"
    exit 0
  fi
done

# ── Detect platform / architecture ────────────────────────────────────────────
OS="$(uname -s)"
ARCH="$(uname -m)"

case "${OS}" in
  Darwin)
    case "${ARCH}" in
      arm64)   PY_TRIPLE="aarch64-apple-darwin";;
      x86_64)  PY_TRIPLE="x86_64-apple-darwin";;
      *)        die "Unsupported macOS architecture: ${ARCH}";;
    esac
    ;;
  Linux)
    case "${ARCH}" in
      x86_64)  PY_TRIPLE="x86_64-unknown-linux-gnu";;
      aarch64) PY_TRIPLE="aarch64-unknown-linux-gnu";;
      armv7l)  PY_TRIPLE="armv7-unknown-linux-gnueabihf";;
      *)        die "Unsupported Linux architecture: ${ARCH}";;
    esac
    ;;
  *)
    die "Unsupported OS: ${OS}. Use pai.cmd on Windows."
    ;;
esac

PY_TARBALL="cpython-${PAI_PYTHON_VERSION}+${PAI_PYTHON_RELEASE}-${PY_TRIPLE}-install_only.tar.gz"
PY_URL="https://github.com/indygreg/python-build-standalone/releases/download/${PAI_PYTHON_RELEASE}/${PY_TARBALL}"
PY_BIN="${PAI_PYTHON_DIR}/bin/python3"

# ── Detect if we already have a good Python ───────────────────────────────────
_python_ok() {
  local bin="$1"
  [[ -x "$bin" ]] || return 1
  local ver
  ver=$("$bin" -c "import sys; print(sys.version_info >= (3,10))" 2>/dev/null) || return 1
  [[ "$ver" == "True" ]]
}

_find_python() {
  # 1. Env override
  if [[ -n "${PAI_PYTHON_BIN}" ]] && _python_ok "${PAI_PYTHON_BIN}"; then
    echo "${PAI_PYTHON_BIN}"; return 0
  fi
  # 2. Embedded (already downloaded)
  if _python_ok "${PY_BIN}"; then
    echo "${PY_BIN}"; return 0
  fi
  # 3. Venv Python (already bootstrapped)
  if _python_ok "${PAI_VENV_DIR}/bin/python3"; then
    echo "${PAI_VENV_DIR}/bin/python3"; return 0
  fi
  # 4. System Python 3.10+
  # Prefer 3.12 over 3.13: torch/sentence-transformers have no 3.13 wheels yet
  for candidate in python3.12 python3.11 python3.10 python3.13 python3; do
    if command -v "$candidate" &>/dev/null && _python_ok "$(command -v "$candidate")"; then
      echo "$(command -v "$candidate")"; return 0
    fi
  done
  return 1
}

# ── Download embedded Python (python-build-standalone) ───────────────────────
_download_python() {
  info "No suitable Python found — downloading embedded Python ${PAI_PYTHON_VERSION}…"
  info "Platform: ${OS} ${ARCH} → ${PY_TRIPLE}"
  info "Source  : ${PY_URL}"
  echo ""

  local tmp_tar="${PAI_HOME}/${PY_TARBALL}"

  # Choose downloader
  if command -v curl &>/dev/null; then
    curl -L --progress-bar --retry 3 --retry-delay 5 \
         -o "${tmp_tar}" "${PY_URL}" || die "Download failed. Check network."
  elif command -v wget &>/dev/null; then
    wget --progress=bar:force -O "${tmp_tar}" "${PY_URL}" || die "Download failed."
  else
    die "Neither curl nor wget found. Install one and retry."
  fi

  echo ""
  info "Extracting Python runtime…"
  mkdir -p "${PAI_PYTHON_DIR}"
  tar -xzf "${tmp_tar}" -C "${PAI_HOME}" 2>/dev/null
  # python-build-standalone extracts to 'python/' — rename if needed
  if [[ -d "${PAI_HOME}/python/bin" ]]; then
    : # already correct
  elif [[ -d "${PAI_HOME}/python/install/bin" ]]; then
    mv "${PAI_HOME}/python/install"/* "${PAI_PYTHON_DIR}/"
  fi
  rm -f "${tmp_tar}"

  if ! _python_ok "${PY_BIN}"; then
    die "Extraction failed — ${PY_BIN} not found or not executable."
  fi
  ok "Embedded Python ${PAI_PYTHON_VERSION} ready at ${PAI_PYTHON_DIR}"
}

# ── Venv health checks ────────────────────────────────────────────────────────
_venv_ok() {
  [[ -x "${PAI_VENV_DIR}/bin/python3" ]] && \
    "${PAI_VENV_DIR}/bin/python3" -c "import fastapi, uvicorn, rich, streamlit" 2>/dev/null
}

_venv_corrupt() {
  # Venv dir exists but Python binary is missing or crashes
  [[ -d "${PAI_VENV_DIR}" ]] && ! [[ -x "${PAI_VENV_DIR}/bin/python3" ]]
}

_venv_repair() {
  warn "Venv is corrupt or incomplete — removing and rebuilding…"
  rm -rf "${PAI_VENV_DIR}"
  ok "Removed corrupt venv. Re-bootstrapping…"
}

# ── Bootstrap venv and deps (runs once) ───────────────────────────────────────
_bootstrap() {
  # Prevent concurrent bootstraps
  if [[ -e "${PAI_LOCK}" ]]; then
    local lock_pid
    lock_pid=$(cat "${PAI_LOCK}" 2>/dev/null || echo "")
    if [[ -n "$lock_pid" ]] && kill -0 "$lock_pid" 2>/dev/null; then
      warn "Another bootstrap is running (PID ${lock_pid}). Waiting…"
      local waited=0
      while [[ -e "${PAI_LOCK}" ]]; do
        sleep 2; waited=$((waited+2))
        [[ $waited -gt 600 ]] && die "Bootstrap lock timed out (>10 min). Remove: ${PAI_LOCK}"
      done
      return 0
    fi
    rm -f "${PAI_LOCK}"
  fi

  echo "$$" > "${PAI_LOCK}"
  trap 'rm -f "${PAI_LOCK}"; echo ""' EXIT INT TERM

  local python="$1"
  local vpython="${PAI_VENV_DIR}/bin/python3"
  # Use a dedicated install log that is OVERWRITTEN each time bootstrap runs.
  # This prevents the log from growing on every invocation and keeps it readable.
  local INSTALL_LOG="${PAI_HOME}/install.log"
  local ts
  ts="$(date '+%Y-%m-%d %H:%M:%S')"

  # Truncate install log and write a fresh header
  {
    echo "====================================================="
    echo " Linus PAI bootstrap  ${ts}"
    echo " Python: ${python}"
    echo " Platform: ${OS} ${ARCH}"
    echo "====================================================="
  } > "${INSTALL_LOG}"

  # bootstrap.log is append-only for errors/warnings only (no banner spam)
  echo "[${ts}] Bootstrap started" >> "${PAI_LOG}"

  _banner
  info "First-run setup — this takes 5–15 minutes once, then instant."
  info "Install log: ${INSTALL_LOG}"
  echo ""

  # Step 1 — Create venv
  info "[1/4] Creating virtual environment…"
  if ! "$python" -m venv "${PAI_VENV_DIR}" >> "${INSTALL_LOG}" 2>&1; then
    echo "[ERROR] venv creation failed — see ${INSTALL_LOG}" >> "${PAI_LOG}"
    err "venv creation failed."
    err "Log: ${INSTALL_LOG}"
    err "Recovery: check disk space (need ≥ 2 GB) and Python version."
    err "  Try: ${python} -m venv /tmp/test_venv"
    die "Bootstrap aborted."
  fi
  ok "Virtual environment: ${PAI_VENV_DIR}"

  # Step 2 — Upgrade pip (errors to install log only)
  info "[2/4] Upgrading pip…"
  "$vpython" -m pip install --upgrade pip wheel setuptools -q \
    >> "${INSTALL_LOG}" 2>&1 || \
    warn "pip upgrade failed — continuing anyway."

  # Step 3 — Install deps
  # stdout goes to terminal (user sees pai.py progress bars live)
  # stderr goes to install log (pip warnings, compile output)
  info "[3/4] Installing dependencies and compiling GPU backend…"
  info "Platform: ${OS} ${ARCH}"
  echo ""
  if ! PAI_DATA_DIR="${PAI_HOME}/data" \
       "$vpython" "${PAI_SCRIPT}" --force-install 2>>"${INSTALL_LOG}"; then
    echo "[ERROR] Dependency install failed — see ${INSTALL_LOG}" >> "${PAI_LOG}"
    err ""
    err "Dependency install failed."
    err "Log: ${INSTALL_LOG}"
    err ""
    err "Recovery options:"
    err "  1. Re-run:   PAI_HOME=${PAI_HOME} ${PAI_REAL_SCRIPT} --force-install"
    err "  2. Manual:   source ${PAI_VENV_DIR}/bin/activate && pip install -r requirements.txt"
    err "  3. Doctor:   PAI_HOME=${PAI_HOME} ${PAI_REAL_SCRIPT} --doctor"
    die "Bootstrap aborted."
  fi

  # Step 4 — Verify
  info "[4/4] Verifying installation…"
  if ! _venv_ok; then
    warn "Some packages may not have installed correctly."
    warn "Run --doctor for a detailed check."
  else
    ok "Installation verified."
  fi

  echo "[$(date '+%Y-%m-%d %H:%M:%S')] Bootstrap succeeded" >> "${PAI_LOG}"
  rm -f "${PAI_LOCK}"
  trap - EXIT INT TERM

  echo ""
  ok "Linus PAI is ready!"
  ok "Run: ${PAI_REAL_SCRIPT} --chat   or   ${PAI_REAL_SCRIPT} --doctor"
  ok "Install log: ${INSTALL_LOG}"
  echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
  # ── 1. Find or download Python ───────────────────────────────────────────────
  PYTHON="$(_find_python 2>/dev/null || true)"

  if [[ -z "${PYTHON}" ]]; then
    info "No Python 3.10+ found on this system."
    _download_python
    PYTHON="${PY_BIN}"
  fi

  # ── 2. Detect and repair corrupt venv ────────────────────────────────────────
  if _venv_corrupt; then
    _venv_repair
  fi

  # ── 3. Bootstrap venv if missing or incomplete ───────────────────────────────
  if ! _python_ok "${PAI_VENV_DIR}/bin/python3" || ! _venv_ok; then
    _bootstrap "${PYTHON}"
  fi

  # ── 4. Final sanity check ─────────────────────────────────────────────────────
  VENV_PYTHON="${PAI_VENV_DIR}/bin/python3"
  if ! [[ -x "${VENV_PYTHON}" ]]; then
    err "venv Python not found at: ${VENV_PYTHON}"
    err "Recovery: re-run this script (will rebuild venv automatically)"
    err "  rm -rf ${PAI_VENV_DIR} && ${PAI_REAL_SCRIPT}"
    exit 1
  fi
  if ! [[ -f "${PAI_SCRIPT}" ]]; then
    err "pai.py not found at: ${PAI_SCRIPT}"
    err "Recovery: re-clone the repo or re-download the binary"
    err "  curl -Lo pai https://github.com/miryala3/linus-pai/releases/latest/download/pai-macos-x86_64"
    exit 1
  fi

  # ── 5. Launch — forward all arguments ────────────────────────────────────────
  PAI_DATA_DIR="${PAI_HOME}/data" \
  exec "${VENV_PYTHON}" "${PAI_SCRIPT}" "$@"
}

main "$@"
